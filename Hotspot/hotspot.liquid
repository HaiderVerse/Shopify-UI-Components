.ks-tooltip.show { display: block; animation: ks_tooltip_animation_showing .4s ease-out both; } 
.ks-tooltip.hiding { display: block; animation: ks_tooltip_animation_hiding .2s ease-out both; } 
@keyframes ks_tooltip_animation_showing { from { opacity: 0; transform: translateY(1rem) } 
to { opacity: 1; transform: translateY(0)} } 
@keyframes ks_tooltip_animation_hiding { to { opacity: 0; transform: translateY(1rem)} }
