  class KsLookBook extends HTMLElement {
  constructor() {
    super();

    this.injectVendorScripts();
    this.querySelectorAll('.ks-lookbook-point-list-item').forEach((elem) => {
      this.handleTooltip(elem);
    });
  }

  async injectVendorScripts() {
    if (!window.FloatingUICore) {
      const script = document.createElement('script');
      script.setAttribute('src', 'https://cdn.jsdelivr.net/npm/@floating-ui/core@1.6.0');
      document.head.appendChild(script);
    }

    if (!window.FloatingUIDOM) {
      await new Promise(r => setTimeout(r, 500)); // short delay to allow core to load

      const script = document.createElement('script');
      script.setAttribute('src', 'https://cdn.jsdelivr.net/npm/@floating-ui/dom@1.6.1');
      document.head.appendChild(script);
    }
  }

handleTooltip(elem) {
  const btn = elem.querySelector('button');
  const tooltip = elem.querySelector('.ks-tooltip');

  function update() {
    window.FloatingUIDOM.computePosition(btn, tooltip, {
      middleware: [
        window.FloatingUIDOM.offset(0),
        window.FloatingUIDOM.autoPlacement(),
      ],
    }).then(({ x, y }) => {
      Object.assign(tooltip.style, {
        left: `${x}px`,
        top: `${y}px`,
        position: 'absolute',
        zIndex: 1000,
      });
    });
  }

  function hideAllTooltips() {
    document.querySelectorAll('.ks-tooltip.show').forEach((t) => {
      t.classList.remove('show');
    });
  }

  function showTooltip() {
    hideAllTooltips(); // hide any open tooltip
    tooltip.classList.add('show');
    update();
  }

  function hideTooltip() {
    tooltip.classList.remove('show');
  }

  // Show on hover (desktop)
  ['mouseenter', 'focus'].forEach(event => {
    btn.addEventListener(event, showTooltip);
  });

  // Show on touch/click (mobile)
  btn.addEventListener('touch', function (e) {
    e.preventDefault();
    if (tooltip.classList.contains('show')) {
      hideTooltip();
    } else {
      hideAllTooltips(); // hide others before showing
      showTooltip();
    }
  });

  // Hide on mouseleave (desktop)
  tooltip.addEventListener('mouseleave', hideTooltip);

  // Hide when tapping outside (mobile)
  document.addEventListener('click', function (e) {
    if (!elem.contains(e.target)) {
      hideTooltip();
    }
  });
}

    
}

customElements.define('ks-lookbook', KsLookBook);

{%- endjavascript -%}

<ks-lookbook 
  id="ks-lookbook-{{ section.id }}"
  class="ks-lookbook"
  style="
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.pt }}rem;
    padding-bottom: {{ section.settings.pb }}rem;
  ">
  <div 
    class="section-header page-width" 
    style="text-align: {{ section.settings.header_text_align }};">
    {%- if section.settings.heading != blank -%}
      <h2 data-aos="fade-down" data-aos-duration="700"
        id="ks-lookbook-heading" 
        class="title inline-richtext {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}
    {%- if section.settings.description != blank %}
      <div class="description rte">
        {{ section.settings.description }}
      </div>
    {% endif %}
  </div>

  <div 
    class="{% if section.settings.container %}container{% endif %}"
    style="max-width: {{ section.settings.container_max_width | append: 'px' }}">

    <div class="ks-lookbook-inner">
      <div class="img-wrapper img-wrapper-mobile">
        {% if section.settings.mobile_image == nil %}
          {{ 'lifestyle-1' | placeholder_svg_tag }}
        {% else %}
          <img
            src="{{ section.settings.mobile_image.src | image_url: width: 800 }}"
            alt="{{ section.settings.mobile_image.alt | escape }}"
            class=""
            width="800"
            height="{{ 600 | divided_by: section.settings.mobile_image.aspect_ratio | round }}"
            loading="lazy">
        {% endif %}
      </div>
      <div class="img-wrapper img-wrapper-desktop">
        {% if section.settings.desktop_image == nil %}
          {{ 'lifestyle-1' | placeholder_svg_tag }}
        {% else %}
          <img 
            src="{{ section.settings.desktop_image.src | image_url: width: 1600 }}"
            alt="{{ section.settings.desktop_image.alt | escape }}"
            class=""
            width="1600"
            height="{{ 1600 | divided_by: section.settings.desktop_image.aspect_ratio | round }}"
            loading="lazy">
        {% endif %}
      </div>
      <div 
        class="ks-lookbook-point-list" 
        aria-labelledby="ks-lookbook-heading"
        role="list">
        {% for block in section.blocks %}
          <div 
            class="ks-lookbook-point-list-item" 
            {{ block.shopify_attributes }}
            role="listitem">
            {% liquid
              assign product = block.settings.product 
            %}
            <button data-aos="fade-right" data-aos-duration="700">
             <svg width="33" height="33" viewBox="0 0 33 33" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="16.4423" cy="16.4423" r="16.4423" fill="#D7342B"/>
              <path d="M14.454 23.9968V18.5251H9V15.218H14.454V9.77637H17.7949V15.218H23.2204V18.5251H17.7949V23.9968H14.454Z" fill="#F6F6F6"/>
              </svg>
            </button>
            <div class="ks-tooltip" role="tooltip">                        
              {% comment %}    <img 
                    class="ks-lookbook-product-img" 
                    src="{{ block.settings.pro_image | img_url:'master' }}" 
                    width="600"
                    height="auto" 
                    loading="lazy">  {% endcomment %}
               {% unless block.settings.title == blank %}
                 <h6 class="subtitle">
                  {{ block.settings.sub_head }}
                </h6>
                <h3 class="title">
                  {{ block.settings.title }}
                </h3>
              {% endunless %} 
              {% if product != nil and block.settings.show_price %} 
                <p class="ks-lookbook-product-price">
                  {% if product.compare_at_price > product.price %}
                    <span class="ks-lookbook-product-price-compare">
                      <span class="visually-hidden visually-hidden--inline">
                        Regular price
                      </span>
                      <s>{{ product.compare_at_price | money }}</s>
                    </span>
                  {% endif %}
                  <span class="ks-lookbook-product-price-final">
                    {{ product.price | money }}
                  </span>
                </p>
              {% endif %}
              {% unless block.settings.description == blank %}
                <div class="description rte">
                  {{ block.settings.description }}
                </div>
              {% endunless %}
              {% if product != nil and block.settings.btn_text != blank %} 
                <a 
                  class="button tip_btn button--primary btn-primary"
                  href="{{ product.url }}"
                  aria-hidden="true">
                  {{ block.settings.btn_text }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

    </div>
  </div>
</ks-lookbook>

{% schema %}
